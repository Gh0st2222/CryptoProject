# Copy to .env and fill in to enable LIVE trading and authenticated endpoints.
# Paper trading and backtesting work WITHOUT keys (public market data only).
#
# Create keys at: BingX -> API Management. Enable "Perpetual Futures Trading"
# permission. Restrict by IP if possible. NEVER commit this file.
BINGX_API_KEY=
BINGX_API_SECRET=

# Optional overrides
# BOT_HOST=127.0.0.1
# BOT_PORT=8420

# Optional: CoinGecko demo API key for the radar's eligibility universe
# (the top-100 tokens by market cap). Works without a key at low rates;
# a free demo key from coingecko.com raises the rate limit.
# COINGECKO_API_KEY=
